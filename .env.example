# ─── OpenAI ────────────────────────────────────────────────────────────────
# Required: OpenAI API key  →  https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_DEFAULT_MODEL=gpt-4o

# ─── Web Search ────────────────────────────────────────────────────────────
# Required: Tavily API key for web search  →  https://tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# ─── University ────────────────────────────────────────────────────────────
# Full name of the university (used in agent instructions and search queries)
UNIVERSITY_NAME=Your University Name

# Comma-separated URL patterns (supports wildcards) for the official university
# website. Only pages matching these patterns will be fetched by the searcher.
UNIVERSITY_URL_PATTERN=*.youruniversity.edu/*

# Any additional information about the student or the university that might be relevant for the agent to know when answering questions. 
# This could include details about the student such as year and department, or any specific areas of interest.
STUDENT_INFO=Your student information here (e.g., "I am a second-year computer science student interested in AI research.")
